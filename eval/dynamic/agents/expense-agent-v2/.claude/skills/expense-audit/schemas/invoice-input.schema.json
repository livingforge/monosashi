{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "expense-audit/schemas/invoice-input.schema.json",
  "title": "請求書入力",
  "type": "object",
  "required": ["invoiceId", "issuer", "issueDate", "dueDate", "lines", "totals"],
  "properties": {
    "invoiceId": { "type": "string" },
    "issuer": {
      "type": "object",
      "required": ["registrationNumber"],
      "properties": {
        "name": { "type": "string" },
        "registrationNumber": { "type": "string" }
      }
    },
    "issueDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "dueDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["quantity", "unitPrice", "taxRate"],
        "properties": {
          "description": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "unitPrice": { "type": "integer", "minimum": 0 },
          "taxRate": { "type": "number" }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": ["taxExcluded", "tax", "taxIncluded"],
      "properties": {
        "taxExcluded": { "type": "integer" },
        "tax": { "type": "integer" },
        "taxIncluded": { "type": "integer" }
      }
    }
  }
}
